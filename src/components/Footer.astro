---
const base = import.meta.env.BASE_URL;
---

<footer class="bg-[#444] text-white">
  <div class="max-w-6xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      <!-- Column 1: Company info -->
      <div>
        <h4 class="text-sm font-semibold uppercase tracking-wide text-[#FF6600] mb-4">Lapsy S.r.l.</h4>
        <address class="text-sm text-gray-300 not-italic leading-relaxed">
          P.IVA IT03447571203
        </address>

        <h4 class="text-sm font-semibold uppercase tracking-wide text-[#FF6600] mt-6 mb-4">Sede Legale</h4>
        <address class="text-sm text-gray-300 not-italic leading-relaxed">
          Via P.A. Orlandi, 11/1/B<br />
          40139 Bologna — Italy
        </address>

        <h4 class="text-sm font-semibold uppercase tracking-wide text-[#FF6600] mt-6 mb-4">Sede Operativa</h4>
        <address class="text-sm text-gray-300 not-italic leading-relaxed">
          Piazza Sergio Finocchi, 3<br />
          41017 Spilamberto (MO) — Italy
        </address>
      </div>

      <!-- Column 2: About PAL -->
      <div>
        <h4 class="text-sm font-semibold uppercase tracking-wide text-[#FF6600] mb-4">Persone al Lavoro</h4>
        <p class="text-sm text-gray-300 leading-relaxed">
          Piattaforma web per la gestione del personale: presenze, accessi in cantiere, badge, formazione e reportistica. Facile, intuitiva, accessibile ovunque.
        </p>
      </div>

      <!-- Column 3: Contatti -->
      <div>
        <h4 class="text-sm font-semibold uppercase tracking-wide text-[#FF6600] mb-4">Contatti</h4>
        <div class="text-sm text-gray-300 space-y-3">
          <a href="tel:+393480407500" class="flex items-center gap-2 hover:text-[#FF6600] active:text-[#e65c00] transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4 text-[#FF6600] shrink-0">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
            </svg>
            +39 348 040 7500
          </a>
          <a href="mailto:info@lapsy.me" class="flex items-center gap-2 hover:text-[#FF6600] active:text-[#e65c00] transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4 text-[#FF6600] shrink-0">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
            </svg>
            info@lapsy.me
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-gray-600">
    <div class="max-w-6xl mx-auto px-4 py-4 flex flex-wrap items-center justify-between gap-4 text-xs text-gray-400">
      <nav class="flex flex-wrap gap-4">
        <a href={`${base}contatti/`} class="hover:text-white transition-colors">Contatti</a>
        <a href={`${base}cookie/`} class="hover:text-white transition-colors">Informativa Cookie</a>
        <a href={`${base}privacy/`} class="hover:text-white transition-colors">Privacy Policy</a>
      </nav>
      <span>&copy; {new Date().getFullYear()} Lapsy S.r.l. — P.IVA IT03447571203</span>
    </div>
  </div>
</footer>
