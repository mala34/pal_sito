---
import PostCard from "./PostCard.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  posts: CollectionEntry<"posts">[];
  emptyMessage?: string;
}

const { posts, emptyMessage = "Nessun contenuto disponibile." } = Astro.props;
---

{posts.length > 0 ? (
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {posts.map((post) => (
      <PostCard
        title={post.data.title}
        slug={post.id}
        tipo={post.data.tipo}
        categoria={post.data.categoria}
        date={post.data.date}
        description={post.data.description}
        image={post.data.image}
        luogo={post.data.luogo}
        durata={post.data.durata}
      />
    ))}
  </div>
) : (
  <div class="text-center py-16">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-12 mx-auto text-gray-300 mb-4">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m5.231 13.481L15 17.25m-4.5-15H5.625c-.621 0-1.125.504-1.125 1.125v16.5c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Zm3.75 11.625a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
    </svg>
    <p class="text-gray-400">{emptyMessage}</p>
  </div>
)}
