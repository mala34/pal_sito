---
// Hero section — Persone al Lavoro (inspired by Tailwind Plus split hero)
// Right-side image rotates every 5s with overlay text per slide
const base = import.meta.env.BASE_URL;

interface Slide {
  src: string;
  alt: string;
  label: string;
  href: string;
}

const slides: Slide[] = [
  {
    src: `${base}images/hero/slide-1-badge.png`,
    alt: "Badge di Cantiere PAL",
    label: "Il nuovo Badge di Cantiere PAL",
    href: `${base}badge-cantiere/`,
  },
  {
    src: `${base}images/hero/slide-2-ai.png`,
    alt: "AI multilingua per il posto di lavoro",
    label: "Abbatti le barriere linguistiche sul posto di lavoro",
    href: `${base}multilingue/`,
  },
  {
    src: `${base}images/hero/slide-3-sicurezza.png`,
    alt: "Sicurezza in cantiere con PAL",
    label: "Più sicurezza grazie all'intelligenza artificiale",
    href: `${base}sicurezza-ia/`,
  },
  {
    src: `${base}images/hero/slide-4-presenze.png`,
    alt: "Gestione presenze e accessi in cantiere",
    label: "Gestisci presenze e accessi in cantiere",
    href: `${base}funzionalita/`,
  },
];
---

<div class="relative isolate overflow-hidden bg-gradient-to-b from-orange-100/20 pt-14">
  <!-- Skewed background shape -->
  <div
    aria-hidden="true"
    class="absolute inset-y-0 right-1/2 -z-10 -mr-96 w-[200%] origin-top-right skew-x-[-30deg] bg-white shadow-xl ring-1 shadow-orange-600/10 ring-orange-50 sm:-mr-80 lg:-mr-96"
  ></div>

  <div class="mx-auto max-w-7xl px-6 py-32 sm:py-40 lg:px-8">
    <div class="mx-auto max-w-2xl lg:mx-0 lg:grid lg:max-w-none lg:grid-cols-2 lg:gap-x-16 lg:gap-y-8 xl:grid-cols-1 xl:grid-rows-1 xl:gap-x-8">

      <!-- Title (fixed) -->
      <h1 class="max-w-2xl text-5xl font-semibold tracking-tight text-balance text-gray-900 sm:text-7xl lg:col-span-2 xl:col-auto">
        Un nuovo modo di gestire il personale
      </h1>

      <!-- Description + CTA (fixed, left column) -->
      <div class="mt-6 max-w-xl lg:mt-0 xl:col-end-1 xl:row-start-1">
        <p class="text-lg font-medium text-pretty text-gray-500 sm:text-xl/8">
          La piattaforma web per la gestione del personale: presenze, accessi in cantiere, badge, corsi di formazione e reportistica.
          Facile, intuitiva, accessibile ovunque — per aziende da 1 a oltre 1000 dipendenti.
        </p>
        <div class="mt-10 flex items-center gap-x-6">
          <a
            href={`${base}contatti/`}
            class="rounded-xl bg-[#FF6600] px-3.5 py-2.5 text-sm font-semibold text-white shadow-xs hover:bg-[#e65c00] active:bg-[#cc5200] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#FF6600] transition-colors"
          >
            Richiedi una demo
          </a>
          <a href="mailto:info@lapsy.me" class="text-sm/6 font-semibold text-gray-900 hover:text-[#FF6600] active:text-[#e65c00] transition-colors">
            Contattaci <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </div>

      <!-- Slideshow image (right column) — images as background with overlay text -->
      <div class="relative mt-10 aspect-6/5 w-full max-w-lg rounded-2xl overflow-hidden outline-1 -outline-offset-1 outline-black/5 sm:mt-16 lg:mt-0 lg:max-w-none xl:row-span-2 xl:row-end-2 xl:mt-36">
        {slides.map((slide, i) => (
          <div
            class:list={[
              "hero-slide absolute inset-0 transition-opacity duration-1000 ease-in-out",
              i === 0 ? "opacity-100" : "opacity-0",
            ]}
            data-index={i}
          >
            <!-- Background image -->
            <img
              src={slide.src}
              alt={slide.alt}
              loading={i === 0 ? "eager" : "lazy"}
              class="absolute inset-0 w-full h-full object-cover"
            />
            <!-- Overlay gradient + text -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
            <div class="absolute inset-x-0 bottom-0 p-6 sm:p-8">
              <p class="text-white text-lg sm:text-xl font-semibold leading-snug drop-shadow-sm">
                {slide.label}
              </p>
              <a
                href={slide.href}
                class="mt-3 inline-flex items-center gap-1.5 rounded-xl bg-white/10 backdrop-blur-sm px-3.5 py-2 text-sm font-semibold text-white hover:bg-[#FF6600] active:bg-[#e65c00] transition-colors"
              >
                Scopri di più
                <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                </svg>
              </a>
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>

  <!-- Bottom fade -->
  <div class="absolute inset-x-0 bottom-0 -z-10 h-24 bg-gradient-to-t from-white sm:h-32"></div>
</div>

<script>
  const slides = document.querySelectorAll<HTMLElement>(".hero-slide");
  if (slides.length > 1) {
    let current = 0;
    slides.forEach((s, i) => {
      if (i !== 0) s.style.pointerEvents = "none";
    });
    setInterval(() => {
      slides[current].classList.replace("opacity-100", "opacity-0");
      slides[current].style.pointerEvents = "none";
      current = (current + 1) % slides.length;
      slides[current].classList.replace("opacity-0", "opacity-100");
      slides[current].style.pointerEvents = "auto";
    }, 5000);
  }
</script>
