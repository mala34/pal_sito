---
// Hero section — Persone al Lavoro (dark app screenshot layout)
const base = import.meta.env.BASE_URL;
---

<div class="relative isolate overflow-hidden bg-white">
  <!-- Grid background pattern -->
  <svg
    aria-hidden="true"
    class="absolute inset-0 -z-10 size-full [mask-image:radial-gradient(100%_100%_at_top_right,white,transparent)] stroke-gray-200"
  >

    <svg x="50%" y="-1" class="overflow-visible fill-gray-50">
      <path
        d="M-200 0h201v201h-201Z M600 0h201v201h-201Z M-400 600h201v201h-201Z M200 800h201v201h-201Z"
        stroke-width="0"
      />
    </svg>
    <rect fill="url(#hero-grid)" width="100%" height="100%" stroke-width="0" />
  </svg>

  <!-- Gradient blur blob -->
  <div
    aria-hidden="true"
    class="absolute top-10 left-[calc(50%-4rem)] -z-10 transform-gpu blur-3xl sm:left-[calc(50%-18rem)] lg:top-[calc(50%-30rem)] lg:left-48 xl:left-[calc(50%-24rem)]"
  >
    <div
      style="clip-path: polygon(73.6% 51.7%, 91.7% 11.8%, 100% 46.4%, 97.4% 82.2%, 92.5% 84.9%, 75.7% 64%, 55.3% 47.5%, 46.5% 49.4%, 45% 62.9%, 50.3% 87.2%, 21.3% 64.1%, 0.1% 100%, 5.4% 51.1%, 21.4% 63.9%, 58.9% 0.2%, 73.6% 51.7%)"
      class="aspect-[1108/632] w-[69.25rem] bg-gradient-to-r from-[#FF6600] to-[#ff9a00] opacity-20"
    ></div>
  </div>

  <div class="mx-auto max-w-7xl px-6 pt-24 pb-24 sm:pb-32 lg:flex lg:px-8 lg:py-40">
    <!-- Left: text content -->
    <div class="mx-auto max-w-2xl shrink-0 lg:mx-0 lg:pt-8">
      <h1 class="mt-10 text-5xl font-semibold tracking-tight text-pretty text-gray-900 sm:text-7xl">
        Un nuovo modo di gestire il personale
      </h1>
      <p class="mt-8 text-lg font-medium text-pretty text-gray-500 sm:text-xl/8">
        La piattaforma web per la gestione del personale: presenze, accessi in cantiere, badge, corsi di formazione e reportistica.
        Facile, intuitiva, accessibile ovunque — per aziende da 1 a oltre 1000 dipendenti.
      </p>
      <div class="mt-10 flex items-center gap-x-6">
        <a
          href={`${base}contatti/`}
          class="rounded-xl bg-[#FF6600] px-3.5 py-2.5 text-sm font-semibold text-white shadow-xs hover:bg-[#e65c00] active:bg-[#cc5200] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#FF6600] transition-colors"
        >
          Richiedi una demo
        </a>
        <a href="mailto:info@lapsy.me" class="text-sm/6 font-semibold text-gray-900 hover:text-[#FF6600] active:text-[#e65c00] transition-colors">
          Contattaci <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>

    <!-- Right: app screenshot -->
    <div class="mx-auto mt-16 flex max-w-2xl sm:mt-24 lg:mt-0 lg:mr-0 lg:ml-10 lg:max-w-none lg:flex-none xl:ml-32">
      <div class="max-w-3xl flex-none sm:max-w-5xl lg:max-w-none">
        <img
          alt="Piattaforma Persone al Lavoro"
          src={`${base}images/hero/pal_web.png`}
          width="2432"
          height="1442"
          fetchpriority="high"
          class="w-[86rem] rounded-xl bg-gray-50 shadow-2xl ring-1 ring-gray-900/10"
        />
      </div>
    </div>
  </div>
</div>
