---
// Security AI section — homepage
const base = import.meta.env.BASE_URL;
---

<div class="mx-auto mt-16 max-w-7xl px-6 sm:mt-20 lg:px-8 pb-16 sm:pb-20">
  <div class="mx-auto flex max-w-2xl flex-col items-center justify-between gap-16 lg:mx-0 lg:max-w-none lg:flex-row lg:items-center">
    <!-- Left: text + image -->
    <div class="w-full lg:max-w-lg lg:flex-auto">
      <h2 class="text-3xl font-semibold tracking-tight text-pretty text-gray-900 sm:text-4xl">
        Più sicurezza sul posto di lavoro grazie all'intelligenza artificiale
      </h2>
      <img
        alt="Sicurezza AI screenshot"
        src={`${base}images/home/sicurezza-screen.png`}
        class="mt-16 aspect-6/5 w-full rounded-2xl object-cover outline-1 -outline-offset-1 outline-black/5 lg:aspect-auto lg:h-[34.5rem]"
      />
    </div>
    <!-- Right: feature list -->
    <div class="w-full lg:max-w-xl lg:flex-auto">
      <!-- Logo badge -->
      <div class="mb-10 inline-flex items-center gap-3 rounded-xl bg-gray-900 px-5 py-3">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-8 text-[#FF6600]">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
        </svg>
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-[#FF6600]">Sicurezza</p>
          <p class="text-lg font-bold text-white leading-tight">Artificiale</p>
        </div>
      </div>

      <p class="mt-6 text-xl/8 text-gray-600">
        "SICUREZZA ARTIFICIALE" è un innovativo servizio che utilizza l'intelligenza artificiale per elaborare le immagini ricevute dal posto di lavoro, identificando potenziali rischi e notificandoli via mail al responsabile della sicurezza della tua Azienda.
      </p>
      <div class="mt-8">
        <a href={`${base}sicurezza-ia/`} class="text-sm/6 font-semibold text-[#FF6600] hover:text-[#e65c00] active:text-[#cc5200] transition-colors">
          Scopri di più <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>
  </div>
</div>
