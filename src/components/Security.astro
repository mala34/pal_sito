---
// Security AI section — homepage (two-column layout)
const base = import.meta.env.BASE_URL;
---

<div class="bg-white py-16 sm:py-24">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="grid grid-cols-1 items-start gap-12 lg:grid-cols-2 lg:gap-16">

      <!-- Left: badge, title, image (mobile only), description, button -->
      <div>
        <!-- Badge -->
        <div class="mb-6 inline-flex items-center gap-3 rounded-xl bg-gray-900 px-5 py-3">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-8 text-[#FF6600]">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
          </svg>
          <div>
            <p class="text-xs font-bold uppercase tracking-[0.2em] text-[#FF6600]">Sicurezza</p>
            <p class="text-lg font-bold text-white leading-tight">Artificiale</p>
          </div>
        </div>

        <!-- Title -->
        <h2 class="text-4xl font-semibold tracking-tight text-pretty text-gray-900 sm:text-5xl mb-8">
          Più sicurezza sul posto di lavoro grazie all'intelligenza artificiale
        </h2>

        <!-- Image (mobile/tablet only) -->
        <img
          alt="Sicurezza AI screenshot"
          src={`${base}images/home/sicurezza-screen.png`}
          loading="lazy"
          class="w-full rounded-xl object-cover mb-8 lg:hidden"
        />

        <!-- Description -->
        <p class="text-lg/8 text-gray-600">
          "SICUREZZA ARTIFICIALE" è un innovativo servizio che utilizza l'intelligenza artificiale per elaborare le immagini ricevute dal posto di lavoro, identificando potenziali rischi e notificandoli via mail al responsabile della sicurezza della tua Azienda.
        </p>

        <!-- CTA -->
        <div class="mt-10">
          <a
            href={`${base}sicurezza-ia/`}
            class="rounded-xl bg-[#FF6600] px-5 py-2.5 text-sm font-semibold text-white shadow-xs hover:bg-[#e65c00] active:bg-[#cc5200] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#FF6600] transition-colors"
          >
            Scopri di più
          </a>
        </div>
      </div>

      <!-- Right: image (desktop only) -->
      <div class="hidden lg:block">
        <img
          alt="Sicurezza AI screenshot"
          src={`${base}images/home/sicurezza-screen.png`}
          loading="lazy"
          class="w-full max-h-[40rem] rounded-xl object-cover"
        />
      </div>

    </div>
  </div>
</div>
