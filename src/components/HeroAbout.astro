---
// HeroAbout section — Persone al Lavoro (split hero with single image)
const base = import.meta.env.BASE_URL;

interface Props {
  title: string;
  description: string;
  image: string;
  imageAlt?: string;
  ctaText?: string;
  ctaHref?: string;
}

const {
  title,
  description,
  image,
  imageAlt = "",
  ctaText = "Richiedi una demo",
  ctaHref = `${base}contatti/`,
} = Astro.props;
---

<div class="relative isolate overflow-hidden bg-gradient-to-b from-orange-100/20 pt-14">
  <!-- Skewed background shape -->
  <div
    aria-hidden="true"
    class="absolute inset-y-0 right-1/2 -z-10 -mr-96 w-[200%] origin-top-right skew-x-[-30deg] bg-white shadow-xl ring-1 shadow-orange-600/10 ring-orange-50 sm:-mr-80 lg:-mr-96"
  ></div>

  <div class="mx-auto max-w-7xl px-6 py-32 sm:py-40 lg:px-8">
    <div class="mx-auto max-w-2xl lg:mx-0 lg:grid lg:max-w-none lg:grid-cols-2 lg:gap-x-16 lg:gap-y-8 xl:grid-cols-1 xl:grid-rows-1 xl:gap-x-8">

      <!-- Title -->
      <h1 class="max-w-2xl text-5xl font-semibold tracking-tight text-balance text-gray-900 sm:text-7xl lg:col-span-2 xl:col-auto">
        {title}
      </h1>

      <!-- Description + CTA (left column) -->
      <div class="mt-6 max-w-xl lg:mt-0 xl:col-end-1 xl:row-start-1">
        <p class="text-lg font-medium text-pretty text-gray-500 sm:text-xl/8">
          {description}
        </p>
        <div class="mt-10 flex items-center gap-x-6">
          <a
            href={ctaHref}
            class="rounded-xl bg-[#FF6600] px-3.5 py-2.5 text-sm font-semibold text-white shadow-xs hover:bg-[#e65c00] active:bg-[#cc5200] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#FF6600] transition-colors"
          >
            {ctaText}
          </a>
          <a href="mailto:info@lapsy.me" class="text-sm/6 font-semibold text-gray-900 hover:text-[#FF6600] active:text-[#e65c00] transition-colors">
            Contattaci <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </div>

      <!-- Image (right column) -->
      <div class="relative mt-10 aspect-6/5 w-full max-w-lg rounded-2xl overflow-hidden outline-1 -outline-offset-1 outline-black/5 sm:mt-16 lg:mt-0 lg:max-w-none xl:row-span-2 xl:row-end-2 xl:mt-36">
        <img
          src={image}
          alt={imageAlt}
          class="absolute inset-0 w-full h-full object-cover"
        />
      </div>

    </div>
  </div>

  <!-- Bottom fade -->
  <div class="absolute inset-x-0 bottom-0 -z-10 h-24 bg-gradient-to-t from-white sm:h-32"></div>
</div>
